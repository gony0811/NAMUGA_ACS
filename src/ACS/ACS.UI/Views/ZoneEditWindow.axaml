<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ACS.UI.Views.ZoneEditWindow"
        Title="Modify Zone"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="Auto,Auto" Margin="12">

        <!-- Zone 정보 -->
        <Border Grid.Row="0" BorderBrush="#999" BorderThickness="1" CornerRadius="3"
                Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Zone Info" FontWeight="SemiBold" FontSize="11"
                           Margin="0,0,0,6" />
                <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" VerticalAlignment="Center" FontSize="11" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="IdTextBox"
                             FontSize="11" Height="28" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bay ID:" VerticalAlignment="Center"
                               FontSize="11" Margin="0,6,0,0" />
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="BayIdComboBox"
                              FontSize="11" Height="30" Margin="0,6,0,0"
                              HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" VerticalAlignment="Center"
                               FontSize="11" Margin="0,6,0,0" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="DescriptionTextBox"
                             FontSize="11" Height="28" Margin="0,6,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
            <Button Content="OK" Width="80" Height="28" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Height="28" Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
