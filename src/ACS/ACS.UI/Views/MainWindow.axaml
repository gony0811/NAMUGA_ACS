<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ACS.UI.ViewModels"
        xmlns:views="using:ACS.UI.Views"
        x:Class="ACS.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ACS - AMR Control System"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="*,Auto">
        <!-- Main content -->
        <Grid Grid.Row="0" ColumnDefinitions="*,350">
            <!-- Map View -->
            <views:MapView Grid.Column="0"
                           DataContext="{Binding MapViewModel}" />

            <!-- Vehicle List -->
            <GridSplitter Grid.Column="0"
                          Width="3"
                          HorizontalAlignment="Right"
                          Background="#404050" />

            <views:VehicleListView Grid.Column="1"
                                   DataContext="{Binding VehicleListViewModel}" />
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1"
                Background="#1E1E2A"
                Padding="10,5">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="10" Height="10"
                             Fill="{Binding ConnectionStatus, Converter={x:Static views:MainWindow.ConnectionStatusToColorConverter}}" />
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="#AAAAAA"
                               VerticalAlignment="Center"
                               FontSize="12" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="{Binding LastUpdateTime, StringFormat='Last Update: {0}'}"
                           Foreground="#AAAAAA"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </Grid>
        </Border>
    </Grid>

</Window>
