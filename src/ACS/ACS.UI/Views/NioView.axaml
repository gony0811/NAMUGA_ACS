<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ACS.UI.ViewModels"
             x:Class="ACS.UI.Views.NioView"
             x:DataType="vm:NioViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ① Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource AcsTabBarBrush}"
                BorderBrush="{StaticResource AcsSectionBorderBrush}"
                BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <StackPanel.Styles>
                    <Style Selector="Button">
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </StackPanel.Styles>

                <TextBlock Text="NIO"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AcsTextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="4,0,12,0" />

                <Button Content="+ Table Option" />
                <Button Content="+ Add" Command="{Binding AddNioCommand}" />
                <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}" />

            </StackPanel>
        </Border>

        <!-- ② NIO DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding NioItems}"
                  SelectedItem="{Binding SelectedNio}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  GridLinesVisibility="All"
                  BorderThickness="0"
                  Background="White"
                  FontSize="11"
                  RowHeight="26"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="80" />
                <DataGridTextColumn Header="INTERFACECLASSNAME" Binding="{Binding InterfaceClassName}" Width="300" />
                <DataGridTextColumn Header="WORKFLOWMANAGERNAME" Binding="{Binding WorkflowManagerName}" Width="150" />
                <DataGridTextColumn Header="APPLICATIONNAME" Binding="{Binding ApplicationName}" Width="120" />
                <DataGridTextColumn Header="PORT" Binding="{Binding Port}" Width="60" />
                <DataGridTextColumn Header="REMOTEIP" Binding="{Binding RemoteIp}" Width="120" />
                <DataGridTextColumn Header="MACHINENAME" Binding="{Binding MachineName}" Width="100" />
                <DataGridTextColumn Header="STATE" Binding="{Binding State}" Width="120" />
                <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="120" />
                <DataGridTextColumn Header="CREATETIME" Binding="{Binding CreateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
