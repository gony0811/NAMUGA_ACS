<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ACS.Host.Test.ViewModels"
        x:Class="ACS.Host.Test.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MES Simulator - Host Communication Tester"
        Width="850" Height="800"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="HeaderedContentControl">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border BorderBrush="#b0bec5" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{TemplateBinding Header}" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#1a3a5c"/>
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Styles>

    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Row 0: Connection Settings -->
        <HeaderedContentControl Grid.Row="0" Header="Connection Settings">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Classes="label" Text="Send Host:" />
                    <TextBox Width="120" Text="{Binding SendHost}" IsEnabled="{Binding !IsConnected}"/>
                    <TextBlock Classes="label" Text="Send Port:" Width="70"/>
                    <TextBox Width="80" Text="{Binding SendPort}" IsEnabled="{Binding !IsConnected}"/>
                    <TextBlock Text="(ACS로 MOVECMD/ACTIONCMD 송신)" Foreground="#999" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Classes="label" Text="Listen Port:" />
                    <TextBox Width="80" Text="{Binding ListenPort}" IsEnabled="{Binding !IsConnected}"/>
                    <TextBlock Text="(ACS로부터 JOBREPORT 수신)" Foreground="#999" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Classes="action" Content="Connect" Command="{Binding ConnectCommand}" IsEnabled="{Binding !IsConnected}" Background="#1565c0" Foreground="White"/>
                    <Button Classes="action" Content="Disconnect" Command="{Binding DisconnectCommand}" IsEnabled="{Binding IsConnected}" Background="#e53935" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="Gray" Name="StatusIndicator"/>
                        <TextBlock Text="{Binding ConnectionStatus}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </HeaderedContentControl>

        <!-- Row 1: Command 송신 (MES → ACS) -->
        <HeaderedContentControl Grid.Row="1" Header="Command 송신 (MES → ACS)">
            <StackPanel Spacing="6">
                <!-- Command Type 선택 -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Classes="label" Text="Command:" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding CommandTypes}"
                              SelectedItem="{Binding SelectedCommandType}"
                              Width="160"/>
                    <Button Classes="action" Content="Send" Command="{Binding SendCommandCommand}"
                            Background="#1565c0" Foreground="White" FontWeight="Bold" MinWidth="100"/>
                </StackPanel>

                <!-- 공통 필드 -->
                <Grid ColumnDefinitions="Auto,*,16,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,0">
                    <!-- Row 0: AcsId / JobID -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="AcsId:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CmdAcsId}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Classes="label" Text="JobID:"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding CmdJobId}"/>

                    <!-- Row 1: MaterialType / UserID -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="field-label" Text="MaterialType:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CmdMaterialType}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Classes="field-label" Text="UserID:"/>
                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding CmdUserId}" Margin="0,4,0,0"/>

                    <!-- Row 2: ActionType -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="field-label" Text="ActionType:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CmdActionType}" Margin="0,4,0,0" Watermark="LOAD / UNLOAD"/>

                    <!-- Row 3: SourceLoc / SourcePort (MOVECMD, MOVECANCEL) -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="field-label" Text="SourceLoc:"
                               IsVisible="{Binding ShowMoveFields}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CmdSourceLoc}" Margin="0,4,0,0"
                             IsVisible="{Binding ShowMoveFields}"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" Classes="field-label" Text="SourcePort:"
                               IsVisible="{Binding ShowMoveFields}"/>
                    <TextBox Grid.Row="3" Grid.Column="4" Text="{Binding CmdSourcePort}" Margin="0,4,0,0"
                             IsVisible="{Binding ShowMoveFields}"/>

                    <!-- Row 4: DestLoc / DestPort (MOVECMD, MOVECANCEL) -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="field-label" Text="DestLoc:"
                               IsVisible="{Binding ShowMoveFields}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CmdDestLoc}" Margin="0,4,0,0"
                             IsVisible="{Binding ShowMoveFields}"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" Classes="field-label" Text="DestPort:"
                               IsVisible="{Binding ShowMoveFields}"/>
                    <TextBox Grid.Row="4" Grid.Column="4" Text="{Binding CmdDestPort}" Margin="0,4,0,0"
                             IsVisible="{Binding ShowMoveFields}"/>

                    <!-- Row 5: TargetLoc / TargetPort (ACTIONCMD) -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="field-label" Text="TargetLoc:"
                               IsVisible="{Binding ShowActionFields}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CmdTargetLoc}" Margin="0,4,0,0"
                             IsVisible="{Binding ShowActionFields}"/>
                    <TextBlock Grid.Row="5" Grid.Column="3" Classes="field-label" Text="TargetPort:"
                               IsVisible="{Binding ShowActionFields}"/>
                    <TextBox Grid.Row="5" Grid.Column="4" Text="{Binding CmdTargetPort}" Margin="0,4,0,0"
                             IsVisible="{Binding ShowActionFields}"/>
                </Grid>
            </StackPanel>
        </HeaderedContentControl>

        <!-- Row 2: Report 수신 (ACS → MES) -->
        <HeaderedContentControl Grid.Row="2" Header="Report 수신 (ACS → MES)">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,4">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Command:" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastReceivedCommand}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#0d47a1"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="JobID:" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastReceivedJobId}" VerticalAlignment="Center" Margin="0,4,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Detail:" Margin="0,4,0,0" VerticalAlignment="Top"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastReceivedDetail}" VerticalAlignment="Top" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#555"/>
            </Grid>
        </HeaderedContentControl>

        <!-- Row 3: Communication Log -->
        <Border Grid.Row="3" BorderBrush="#b0bec5" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Communication Log" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#1a3a5c"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                    <Button Content="Clear" Command="{Binding ClearLogCommand}" Width="70" Height="28"/>
                </StackPanel>
                <TextBox Name="LogTextBox"
                         Text="{Binding LogText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas, Menlo, monospace"
                         FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
