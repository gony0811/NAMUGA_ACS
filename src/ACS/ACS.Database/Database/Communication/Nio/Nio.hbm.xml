<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Communication" namespace = "ACS.Communication.Socket.Model"> <!--.cs 위치-->
  
  <class
      name="Nio"
      table="NA_C_NIO"
      dynamic-update="true"
      dynamic-insert="true"
    >
    <id
        name="Id"
        column="id"
        type="String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Nio.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>


    <property
        name="InterfaceClassName"
        type="System.String"
        update="true"
        insert="true"
        column="interfaceClassName"
        length="255"
        />

    <property
        name="WorkflowManagerName"
        type="System.String"
        update="true"
        insert="true"
        column="workflowManagerName"
        length="255"
        />

    <property
        name="ApplicationName"
        type="System.String"
        update="true"
        insert="true"
        column="applicationName"
        length="64"
        />

    <property
        name="Port"
        type="int"
        update="true"
        insert="true"
        column="port"
        />

    <property
        name="RemoteIp"
        type="System.String"
        update="true"
        insert="true"
        column="remoteIp"
        length="20"
        />

    <property
        name="MachineName"
        type="System.String"
        update="true"
        insert="true"
        column="machineName"
        length="64"
        />


    <property
        name="Name"
        type="System.String"
        update="true"
        insert="true"
        >
      <column
          name="NAME"
          length="64"
          index="NIO_NAME"
          not-null="true"
            />
    </property>

    <property
        name="Description"
        type="System.String"
        update="true"
        insert="true"
        column="description"
        length="255"
        />

    <property
        name="CreateTime"
        type="System.DateTime" 
        update="true"
        insert="true"
        column="createTime"
        />

    <property
        name="Creator"
        type="System.String"
        update="true"
        insert="true"
        column="creator"
        length="45"
        />

    <property
        name="Editor"
        type="System.String"
        update="true"
        insert="true"
        column="editor"
        length="45"
        />

    <property
        name="State"
        type="System.String"
        update="true"
        insert="true"
        column="state"
        length="20"
        />

    <property
        name="EditTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="editTime"
        />

    <!--
            To add non XDoclet property mappings, create a file named
                hibernate-properties-Secs.xml
            containing the additional properties and place it in your merge dir.
        -->

  </class>

</hibernate-mapping>