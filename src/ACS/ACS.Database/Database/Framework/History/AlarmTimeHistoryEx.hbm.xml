<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Extension.Framework" namespace = "ACS.Extension.Framework.History.Model">
  <!--.cs 위치-->
  
    <class
    	name="AlarmTimeHistoryEx"
        table="NA_H_ALARMTIMEHISTORY"
        dynamic-update="true"
        dynamic-insert="true"
    >

        <id
            name="Id"
            column="id"
            type="System.String"
            length="64"
            unsaved-value="null"
        >
            <generator class="assigned">
              <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Alarm.xml 
                  containing the additional parameters and place it in your merge dir. 
              --> 
            </generator>
        </id>

        <property
            name="AlarmCode"
            type="System.String"
            update="true"
            insert="true"
            column="alarmCode"
            length="10"
        />

        <property
            name="AlarmText"
            type="System.String"
            update="true"
            insert="true"
            column="alarmText"
            length="255"
        />

        <property
            name="VehicleId"
            type="System.String"
            update="true"
            insert="true"
            column="vehicleId"
            length="64"
        />
        
        <property
            name="AlarmId"
            type="System.String"
            update="true"
            insert="true"
            column="alarmId"
            length="10"
        />
        
        <property
            name="PartitionId"
            type="int"
            update="true"
            insert="true"
        >
            <column
                name="PARTITIONID" 
                index="ALARMRPTHISTORY_PTID"
                not-null="true"
            />
        </property>

        <property
            name="Time"
            type="System.DateTime"
            update="true"
            insert="true"
            column="time"
        />
        
        <property
            name="CreateTime"
            type="System.DateTime"
            update="true"
            insert="true"
            column="CREATETIME"
        />
        
        <property
            name="ClearTime"
            type="System.DateTime"
            update="true"
            insert="true"
            column="CLEARTIME"
        />
        
        
        <property
            name="TransportCommandId"
            type="System.String"
            update="true"
            insert="true"
            column="transportCommandId"
            length="64"
        />    
        <property
            name="NearAgv"
            type="System.String"
            update="true"
            insert="true"
            column="NEARAGV"
            length="2"
        />
        <property
            name="BayId"
            type="System.String"
            update="true"
            insert="true"
            column="BAYID"
            length="64"
          />
        <property
            name="IsCross"
            type="System.String"
            update="true"
            insert="true"
            column="ISCROSS"
            length="2"
          />      
    </class>
</hibernate-mapping>
