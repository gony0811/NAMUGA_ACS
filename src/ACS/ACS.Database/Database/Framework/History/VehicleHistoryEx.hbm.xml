<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.History.Model">
  <!--.cs 위치-->
  
  <class
    name="VehicleHistoryEx"
      table="NA_H_VEHICLEHISTORY"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Alarm.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />

    <property
        name="BayId"
        type="System.String"
        update="true"
        insert="true"
        column="bayId"
        length="64"
        />

    <property
        name="CarrierType"
        type="System.String"
        update="true"
        insert="true"
        column="carrierType"
        length="8"
        />

    <property
        name="ConnectionState"
        type="System.String"
        update="true"
        insert="true"
        column="connectionState"
        length="16"
        />

    <property
        name="AlarmState"
        type="System.String"
        update="true"
        insert="true"
        column="alarmState"
        length="8"
        />

    <property
        name="ProcessingState"
        type="System.String"
        update="true"
        insert="true"
        column="processingState"
        length="20"
        />

    <property
        name="CurrentNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="currentNodeId"
        length="64"
        />

    <property
        name="TransportCommandId"
        type="System.String"
        update="true"
        insert="true"
        column="transportCommandId"
        length="64"
        />

    <property
        name="Path"
        type="System.String"
        update="true"
        insert="true"
        column="path"
        length="2000"
        />

    <property
        name="NodeCheckTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="nodeCheckTime"
        />

    <property
         name="State"
         type="System.String"
         update="true"
         insert="true"
         column="state"
         length="20"
        />

    <property
        name="Installed"
        type="System.String"
        update="true"
        insert="true"
        column="installed"
        length="20"
        />

    <property
        name="TransferState"
        type="System.String"
        update="true"
        insert="true"
        column="transferState"
        length="20"
        />

    <property
        name="RunState"
        type="System.String"
        update="true"
        insert="true"
        column="runState"
        length="10"
        />

    <property
        name="FullState"
        type="System.String"
        update="true"
        insert="true"
        column="fullState"
        length="10"
        />

    <property
        name="Time"
        type="System.DateTime"
        update="true"
        insert="true"
        column="time"
        />

    <property
        name="MessageName"
        type="System.String"
        update="true"
        insert="true"
        column="messageName"
        length="64"
        />

    <property
        name="AcsDestNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="acsDestNodeId"
        length="64"
        />

    <property
        name="VehicleDestNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleDestNodeId"
        length="64"
        />

    <property
        name="PartitionId"
        type="int"
        update="true"
        insert="true"
        >
      <column
          name="PARTITIONID"
          index="VEHICLEHISTORY_PTID"
          not-null="true"
            />
    </property>

  </class>
</hibernate-mapping>
