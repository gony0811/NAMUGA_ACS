<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.History.Model">
  <!--.cs 위치-->
  
  <class
    name="AlarmReportHistoryEx"
      table="NA_H_ALARMRPTHISTORY"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Alarm.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="AlarmCode"
        type="System.String"
        update="true"
        insert="true"
        column="alarmCode"
        length="10"
        />

    <property
        name="AlarmText"
        type="System.String"
        update="true"
        insert="true"
        column="alarmText"
        length="255"
        />

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />

    <property
        name="AlarmId"
        type="System.String"
        update="true"
        insert="true"
        column="alarmId"
        length="10"
        />

    <property
        name="State"
        type="System.String"
        update="true"
        insert="true"
        column="state"
        length="20"
        />
    <property
        name="PartitionId"
        type="int"
        update="true"
        insert="true"
        >
      <column
          name="PARTITIONID"
          index="ALARMRPTHISTORY_PTID"
          not-null="true"
            />
    </property>

    <property
        name="Time"
        type="System.DateTime"
        update="true"
        insert="true"
        column="time"
        />

    <property
        name="TransportCommandId"
        type="System.String"
        update="true"
        insert="true"
        column="transportCommandId"
        length="64"
        />
  </class>
</hibernate-mapping>
