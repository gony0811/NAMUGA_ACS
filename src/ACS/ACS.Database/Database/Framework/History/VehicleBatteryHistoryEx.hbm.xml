<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.History.Model">
  <!--.cs 위치-->
  
  <class
    name="VehicleBatteryHistoryEx"
      table="NA_H_VEHICLE_BATTERYHISTORY"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Alarm.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />

    <property
       name="BatteryRate"
       type="int"
       update="true"
       insert="true"
       column="batteryRate"
        />

    <property
        name="BatteryVoltage"
        type="float"
        update="true"
        insert="true"
        column="batteryVoltage"
        />

    <property
        name="ProcessingState"
        type="System.String"
        update="true"
        insert="true"
        column="PROCESSINGSTATE"
        length="20"
        />
    
    <property
        name="Time"
        type="System.DateTime"
        update="true"
        insert="true"
        column="time"
        />

    <property
        name="PartitionId"
        type="int"
        update="true"
        insert="true"
        >
      <column
          name="PARTITIONID"
          index="VEHICLEHISTORY_PTID"
          not-null="true"
            />
    </property>

  </class>
</hibernate-mapping>
