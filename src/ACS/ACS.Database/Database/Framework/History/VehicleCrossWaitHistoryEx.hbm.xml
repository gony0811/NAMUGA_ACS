<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Extension.Framework" namespace = "ACS.Extension.Framework.History.Model">
  <!--.cs 위치-->

  <class
    name="VehicleCrossWaitHistoryEx"
      table="NA_H_CROSSWAIT_HISTORY"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Alarm.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />

    <property
        name="NodeId"
        type="System.String"
        update="true"
        insert="true"
        column="NodeId"
        length="64"
        />


    <property
         name="State"
         type="System.String"
         update="true"
         insert="true"
         column="state"
         length="20"
        />

    <property
        name="Time"
        type="System.DateTime"
        update="true"
        insert="true"
        column="time"
        />

    <property
        name="CreateTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="createTime"
        />

    <property
        name="PermitTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="permitTime"
        />

    <property
    name="CrossWaitSeconds"
    type="int"
    update="true"
    insert="true"
    column="crossWaitSeconds"
        />

    <property
        name="PartitionId"
        type="int"
        update="true"
        insert="true"
        >
      <column
          name="PARTITIONID"
          index="VEHICLEHISTORY_PTID"
          not-null="true"
            />
    </property>

  </class>
</hibernate-mapping>
