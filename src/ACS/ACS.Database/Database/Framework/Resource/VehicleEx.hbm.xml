<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="VehicleExs"
      table="NA_R_VEHICLE"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="vehicle"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="NioId"
        type="System.String"
        update="true"
        insert="true"
        column="NIOID"
        length="32"
        />

    <property
        name="Vendor"
        type="System.String"
        update="true"
        insert="true"
        column="vendor"
        length="32"
        />

    <property
        name="Version"
        type="System.String"
        update="true"
        insert="true"
        column="version"
        length="32"
        />

    <property
        name="PlcVersion"
        type="System.String"
        update="true"
        insert="true"
        column="plcVersion"
        length="32"
        />

    <property
        name="BayId"
        type="System.String"
        update="true"
        insert="true"
        column="bayId"
        length="64"
        />

    <property
        name="CarrierType"
        type="System.String"
        update="true"
        insert="true"
        column="carrierType"
        length="8"
        />

    <property
        name="ConnectionState"
        type="System.String"
        update="true"
        insert="true"
        column="connectionState"
        length="16"
        />

    <property
        name="AlarmState"
        type="System.String"
        update="true"
        insert="true"
        column="alarmState"
        length="8"
        />

    <property
        name="ProcessingState"
        type="System.String"
        update="true"
        insert="true"
        column="processingState"
        length="20"
        />

    <property
        name="BatteryRate"
        type="int"
        update="true"
        insert="true"
        column="batteryRate"
        />

    <property
        name="BatteryVoltage"
        type="float"
        update="true"
        insert="true"
        column="batteryVoltage"
        />

    <property
        name="CurrentNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="currentNodeId"
        length="64"
        />

    <property
         name="TransportCommandId"
         type="System.String"
         update="true"
         insert="true"
         column="transportCommandId"
         length="64"
        />

    <property
        name="Path"
        type="System.String"
        update="true"
        insert="true"
        column="path"
        length="2000"
        />

    <property
        name="NodeCheckTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="nodeCheckTime"
        />

    <property
        name="EventTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="eventTime"
        />

    <property
        name="State"
        type="System.String"
        update="true"
        insert="true"
        column="state"
        length="20"
        />

    <property
        name="Installed"
        type="System.String"
        update="true"
        insert="true"
        column="installed"
        length="20"
        />

    <property
         name="TransferState"
         type="System.String"
         update="true"
         insert="true"
         column="transferState"
         length="20"
        />

    <property
        name="RunState"
        type="System.String"
        update="true"
        insert="true"
        column="runState"
        length="10"
        />

    <property
        name="FullState"
        type="System.String"
        update="true"
        insert="true"
        column="fullState"
        length="10"
        />

    <property
        name="AcsDestNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="acsDestNodeId"
        length="64"
        />

    <property
        name="VehicleDestNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleDestNodeId"
        length="64"
        />

    <property
        name="LastChargeTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="LASTCHARGETIME"
        />

    <property
        name="LastChargeBattery"
        type="float"
        update="true"
        insert="true"
        column="LASTCHARGEBATTERY"
        />



    <!--<property
        name="HmiVersion"
        type="System.String"
        update="true"
        insert="true"
        column="HMIVERSION"
        length="20"
        />-->







  </class>

</hibernate-mapping>
