<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Extension.Framework" namespace = "ACS.Extension.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
    name="SpecialConfig"
    table="NA_R_SPECIALCONFIG"
    dynamic-update="true"
    dynamic-insert="true"
    >

    <id
            name="Id"
            column="ID"
            type="System.String"
            length="20"
            unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-SuitableVehicleHistory.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="Name"
        type="System.String"
        update="true"
        insert="true"
        column="CONFIGNAME"
        length="20"
        />

    <property
        name="Values"
        type="System.String"
        update="true"
        insert="true"
        column="CONFIGVALUES"
        length="1000"
        />

  </class>

</hibernate-mapping>