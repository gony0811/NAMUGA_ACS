<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="LocationEx"
      table="NA_R_LOCATION"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="location"
    >

    <id
        name="PortId"
        column="portId"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="StationId"
        type="System.String"
        update="true"
        insert="true"
        column="stationId"
        length="64"
        />

    <property
        name="Type"
        type="System.String"
        update="true"
        insert="true"
        column="type"
        length="8"
        />

    <property
        name="CarrierType"
        type="System.String"
        update="true"
        insert="true"
        column="carrierType"
        length="8"
        />

    <property
        name="Direction"
        type="System.String"
        update="true"
        insert="true"
        column="direction"
        length="8"
        />

    <property
        name="State"
        type="System.String"
        update="true"
        insert="true"
        column="state"
        length="20"
        />

  </class>

</hibernate-mapping>
