<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
	<!--.cs 위치-->

	<class
		name="VehicleIdleEx"
		table="NA_R_VEHICLE_IDLE"
		dynamic-update="true"
		dynamic-insert="true"		
    >

		<id
			name="Id"
			column="id"
			type="System.String"
			length="64"
			unsaved-value="null"
        >
			<generator class="assigned">
				<!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
			</generator>
		</id>

		<property
			name="VehicleId"
			type="System.String"
			update="true"
			insert="true"
			column="vehicleId"
			length="64"
        />

		<property
			name="BayId"
			type="System.String"
			update="true"
			insert="true"
			column="bayId"
			length="64"
        />

		<property
			name="IdleTime"
			type="System.DateTime"
			update="true"
			insert="true"
			column="idleTime"			
        />		
	</class>

</hibernate-mapping>
