<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="LinkZoneEx"
      table="NA_R_LINK_ZONE"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="link_zone"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="LinkId"
        type="System.String"
        update="true"
        insert="true"
        column="linkId"
        length="64"
        />

    <property
        name="ZoneId"
        type="System.String"
        update="true"
        insert="true"
        column="zoneId"
        length="64"
        />

    <property
        name="TransferFlag"
        type="System.String"
        update="true"
        insert="true"
        column="transferFlag"
        length="1"
        />

  </class>

</hibernate-mapping>
