<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="BayEx"
      table="NA_R_BAY"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="bay"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="Floor"
        type="int"
        update="true"
        insert="true"
        column="floor"
        />

    <property
        name="Description"
        type="System.String"
        update="true"
        insert="true"
        column="description"
        length="200"
        />

	  <property
	   name="AgvType"
	   type="System.String"
	   update="true"
	   insert="true"
	   column="agvType"
	   length="20"
        />

	  <property
	   name="ChargeVoltage"
	   type="float"
	   update="true"
	   insert="true"
	   column="chargeVoltage"
        />

	  <property
	   name="LimitVoltage"
	   type="float"
	   update="true"
	   insert="true"
	   column="limitVoltage"
        />

	  <property
	  name="IdleTime"
	  type="int"
	  update="true"
	  insert="true"
	  column="idleTime"
        />

  </class>

</hibernate-mapping>
