<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Extension.Framework" namespace = "ACS.Extension.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="VehicleOrderEx"
      table="NA_R_VEHICLE_ORDER"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />
    
    <property
        name="OrderNode"
        type="System.String"
        update="true"
        insert="true"
        column="orderNode"
        length="20"
        />

    <property
        name="OrderTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="orderTime"
	/>

  </class>

</hibernate-mapping>