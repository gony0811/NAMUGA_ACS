<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="OrderPairNodeEx"
      table="NA_R_ORDER_PAIR"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="OrderGroup"
        type="System.String"
        update="true"
        insert="true"
        column="orderGroup"
        length="64"
        />

    <property
        name="Status"
        type="System.String"
        update="true"
        insert="true"
        column="status"
        length="32"
        />

  </class>

</hibernate-mapping>