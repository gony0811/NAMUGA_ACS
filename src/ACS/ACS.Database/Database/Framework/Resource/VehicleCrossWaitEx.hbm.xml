<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Resource.Model">
  <!--.cs 위치-->

  <class
      name="VehicleCrossWaitEx"
      table="NA_R_VEHICLE_CROSS_WAIT"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="vehicle"
    >

    <id
        name="VehicleId"
        column="vehicleId"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="NodeId"
        type="System.String"
        update="true"
        insert="true"
        column="nodeId"
        length="64"
        />

    <property
        name="State"
        type="System.String"
        update="true"
        insert="true"
        column="state"
        length="20"
        />

    <property
        name="CreatedTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="createdTime"
        />


  </class>

</hibernate-mapping>
