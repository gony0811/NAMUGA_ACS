<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Logging.Model">
  <!--.cs 위치-->

  <class
      name="LargeLogMessage"
      table="NA_L_LARGELOGMESSAGE"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >

      <generator class="assigned">  
        <!--
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-LargeLogMessage.xml 
                  containing the additional parameters and place it in your merge dir. 
         -->
      </generator>
    </id>

    <property
        name="LogMessageId"
        type="System.String"
        update="true"
        insert="true"
        >
      <column
          name="LOGMESSAGEID"
          index="LARGELOGMESSAGEID_LOGMESSAGEID"
          not-null="true"
            />
    </property>

    <property
        name="LargeText"
        type="System.String"
        update="true"
        insert="true"
        column="largeText"
        length="4000"
        />

    <!-- <property
            name="sequence"
            type="int"
            update="true"
            insert="true"
            column="sequence"
            not-null="true"
        /> -->

    <property
        name="PartitionId"
        type="int"
        update="true"
        insert="true"
        >
      <column
          name="PARTITIONID"
          index="LARGELOGMESSAGE_PTID"
          not-null="true"
            />
    </property>

    <property
        name="Time"
        type="System.DateTime"
        update="true"
        insert="true"
        column="time"
        />

    <property
        name="Sequence"
        type="int"
        update="true"
        insert="true"
        column="sequence"
        not-null="true"
        />

    <!--
            To add non XDoclet property mappings, create a file named
                hibernate-properties-LargeLogMessage.xml
            containing the additional properties and place it in your merge dir.
        -->

  </class>

</hibernate-mapping>
