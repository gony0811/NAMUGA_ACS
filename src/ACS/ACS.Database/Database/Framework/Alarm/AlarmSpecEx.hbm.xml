<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Alarm.Model">
  <!--.cs 위치-->
  
  <class
      name="AlarmSpecEx"
      table="NA_A_ALARMSPEC"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-AlarmSpec.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="AlarmId"
        type="System.String"
        update="true"
        insert="true"
        column="alarmId"
        length="10"
        />

    <property
        name="AlarmText"
        type="System.String"
        update="true"
        insert="true"
        column="alarmText"
        length="255"
        />

    <property
        name="Severity"
        type="System.String"
        update="true"
        insert="true"
        column="severity"
        length="10"
        />

    <property
        name="Description"
        type="System.String"
        update="true"
        insert="true"
        column="description"
        length="255"
        />

    <!--
            To add non XDoclet property mappings, create a file named
                hibernate-properties-AlarmSpec.xml
            containing the additional properties and place it in your merge dir.
        -->

  </class>

</hibernate-mapping>
