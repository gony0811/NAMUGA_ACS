<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Alarm.Model">
  <!--.cs 위치-->
  
  <class
      name="AlarmEx"
      table="NA_A_ALARM"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Alarm.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="AlarmCode"
        type="System.String"
        update="true"
        insert="true"
        column="alarmCode"
        length="10"
        />

    <property
        name="AlarmText"
        type="System.String"
        update="true"
        insert="true"
        column="alarmText"
        length="255"
        />

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />

    <property
        name="CreateTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="createTime"
        ></property>

    <property
        name="AlarmId"
        type="System.String"
        update="true"
        insert="true"
        column="alarmId"
        length="10"
        />

    <property
        name="TransportCommandId"
        type="System.String"
        update="true"
        insert="true"
        column="transportCommandId"
        length="64"
        />
    <property
        name="NearAgv"
        type="System.String"
        update="true"
        insert="true"
        column="NEARAGV"
        length="2"
        />
    <property
        name="IsCross"
        type="System.String"
        update="true"
        insert="true"
        column="ISCROSS"
        length="2"
        />
  </class>
</hibernate-mapping>
