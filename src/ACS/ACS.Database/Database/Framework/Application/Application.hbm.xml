<?xml version="1.0" encoding="utf-8" ?> 

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Application.Model">
  <!--.cs 위치-->
  
    <class
        name="Application"
        table="NA_X_APPLICATION"
        dynamic-update="true"
        dynamic-insert="true"
    >

        <id
            name="Id"
            column="id"
            type="System.String"
            length="64"
            unsaved-value="null"
        >
            <generator class="assigned">
              <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Application.xml 
                  containing the additional parameters and place it in your merge dir. 
              --> 
            </generator>
        </id>

        <property
            name="Type"
            type="System.String"
            update="true"
            insert="true"
            column="type"
            length="20"
        />

        <property
            name="State"
            type="System.String"
            update="true"
            insert="true"
            column="state"
            length="20"
        />

        <property
            name="StartTime"
            type="System.DateTime"
            update="true"
            insert="true"
            column="startTime"
        />

        <property
            name="CheckTime"
            type="System.DateTime"
            update="true"
            insert="true"
            column="checkTime"
        />

        <property
            name="InitialHardware"
            type="System.String"
            update="true"
            insert="true"
            column="initialHardware"
            length="45"
        />

        <property
            name="RunningHardware"
            type="System.String"
            update="true"
            insert="true"
            column="runningHardware"
            length="45"
        />

        <property
            name="RunningHardwareAddress"
            type="System.String"
            update="true"
            insert="true"
            column="runningHardwareAddress"
            length="45"
        />

        <property
            name="Msb"
            type="System.String"
            update="true"
            insert="true"
            column="msb"
            length="20"
        />

        <property
            name="Memory"
            type="System.String"
            update="true"
            insert="true"
            column="memory"
            length="5"
        />

        <property
            name="Jmx"
            type="System.String"
            update="true"
            insert="true"
            column="jmx"
            length="10"
        />

        <property
            name="DestinationName"
            type="System.String"
            update="true"
            insert="true"
            column="destinationName"
            length="64"
        />

        <property
            name="Name"
            type="System.String"
            update="true"
            insert="true"
        >
          <column
                name="NAME" 
                length="64"
                index="APPLICATION_NAME"
                not-null="true"
            />
        </property>

        <property
            name="Description"
            type="System.String"
            update="true"
            insert="true"
            column="description"
            length="255"
        />

        <property
            name="CreateTime"
            type="System.DateTime"
            update="true"
            insert="true"
            column="createTime"
        />

        <property
            name="Creator"
            type="System.String"
            update="true"
            insert="true"
            column="creator"
            length="45"
        />

        <property
            name="Editor"
            type="System.String"
            update="true"
            insert="true"
            column="editor"
            length="45"
        />

        <property
            name="EditTime"
            type="System.DateTime"
            update="true"
            insert="true"
            column="editTime"
        />

        <!--
            To add non XDoclet property mappings, create a file named
                hibernate-properties-Application.xml
            containing the additional properties and place it in your merge dir.
        -->

    </class>

</hibernate-mapping>
