<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Path.Model">
  <!--.cs 위치-->
  
  <class
      name="LinkEx"
      table="NA_R_LINK"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="link"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="FromNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="fromNodeId"
        length="64"
        />

    <property
        name="ToNodeId"
        type="System.String"
        update="true"
        insert="true"
        column="toNodeId"
        length="64"
        />

    <property
        name="Length"
        type="int"
        update="true"
        insert="true"
        column="length"
        />

    <property
        name="Speed"
        type="int"
        update="true"
        insert="true"
        column="speed"
        />

    <property
        name="LeftBranch"
        type="int"
        update="true"
        insert="true"
        column="leftBranch"
        />

    <property
        name="Availability"
        type="System.String"
        update="true"
        insert="true"
        column="availability"
        length="2"
        />

    <property
        name="Load"
        type="int"
        update="true"
        insert="true"
        column="load"
        />

    <property
    name="AgvType"
    type="System.String"
    update="true"
    insert="true"
    column="agvtype"
    length="64"
        />


  </class>

</hibernate-mapping>
