<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Path.Model">
  <!--.cs 위치-->
  <class
      name="LocationViewEx"
      table="NA_R_LOCATION_VW"
      dynamic-update="true"
      dynamic-insert="true"
    >

    <id
        name="PortId"
        column="portId"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="StationId"
        type="System.String"
        update="true"
        insert="true"
        column="stationId"
        length="64"
        />

    <property
        name="BayId"
        type="System.String"
        update="true"
        insert="true"
        column="bayId"
        length="64"
        />

    <property
        name="Location_Type"
        type="System.String"
        update="true"
        insert="true"
        column="location_type"
        length="8"
        />

    <property
        name="CarrierType"
        type="System.String"
        update="true"
        insert="true"
        column="carrierType"
        length="8"
        />

    <property
        name="Direction"
        type="System.String"
        update="true"
        insert="true"
        column="direction"
        length="8"
        />

    <property
        name="State"
        type="System.String"
        update="true"
        insert="true"
        column="state"
        length="20"
        />

    <property
        name="LinkId"
        type="System.String"
        update="true"
        insert="true"
        column="linkId"
        length="64"
        />

    <property
        name="ParentNode"
        type="System.String"
        update="true"
        insert="true"
        column="parentNode"
        length="64"
        />

    <property
        name="Station_type"
        type="System.String"
        update="true"
        insert="true"
        column="station_type"
        length="64"
        />

    <property
        name="Distance"
        type="int"
        update="true"
        insert="true"
        column="distance"
        />

    <property
        name="From_xpos"
        type="int"
        update="true"
        insert="true"
        column="from_xpos"
        />

    <property
        name="From_ypos"
        type="int"
        update="true"
        insert="true"
        column="from_ypos"
        />

    <property
        name="To_xpos"
        type="int"
        update="true"
        insert="true"
        column="to_xpos"
        />

    <property
        name="To_ypos"
        type="int"
        update="true"
        insert="true"
        column="to_ypos"
        />

    <property
        name="Length"
        type="int"
        update="true"
        insert="true"
        column="length"
        />

    <!--<property
        name="Speed"
        type="int"
        update="true"
        insert="true"
        column="speed"
        />-->

    <property
        name="LeftBranch"
        type="int"
        update="true"
        insert="true"
        column="leftBranch"
        />

    <property
        name="Availability"
        type="System.String"
        update="true"
        insert="true"
        column="availability"
        length="2"
        />

    <property
        name="Load"
        type="int"
        update="true"
        insert="true"
        column="load"
        />

    <property
        name="TransferFlag"
        type="System.String"
        update="true"
        insert="true"
        column="transferFlag"
        length="64"
        />

  </class>

</hibernate-mapping>
