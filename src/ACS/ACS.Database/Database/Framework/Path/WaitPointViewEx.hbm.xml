<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Extension.Framework" namespace = "ACS.Extension.Framework.Path.Model">
	<!--.cs 위치-->

	<class
		name="WaitPointViewEx"
		table="NA_R_WAITP_VW"
		dynamic-update="true"
		dynamic-insert="true"
    >

		<id
			name="Id"
			column="id"
			type="System.String"
			length="64"
			unsaved-value="null"
        >
			<generator class="assigned">
				<!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
			</generator>
		</id>

		<property
			name="Type"
			type="System.String"
			update="true"
			insert="true"
			column="type"
			length="64"
        />

		<property
			name="ZoneId"
			type="System.String"
			update="true"
			insert="true"
			column="zoneId"
			length="64"
        />
	</class>

</hibernate-mapping>
