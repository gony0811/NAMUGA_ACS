<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Path.Model">
  <!--.cs 위치-->
  <class
      name="StationEx"
      table="NA_R_STATION"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="station"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="LinkId"
        type="System.String"
        update="true"
        insert="true"
        column="linkId"
        length="64"
        />

    <property
        name="Type"
        type="System.String"
        update="true"
        insert="true"
        column="type"
        length="20"
        />

    <property
        name="Distance"
        type="int"
        update="true"
        insert="true"
        column="distance"
        />

  </class>

</hibernate-mapping>
