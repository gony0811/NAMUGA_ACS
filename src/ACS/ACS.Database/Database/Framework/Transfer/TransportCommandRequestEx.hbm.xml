<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns = "urn:nhibernate-mapping-2.2"
   assembly = "ACS.Framework" namespace = "ACS.Framework.Transfer.Model">
  <!--.cs 위치-->
  
  <class
      name="TransportCommandRequestEx"
      table="NA_Q_TRANSPORTCMDREQUEST"
      dynamic-update="true"
      dynamic-insert="true"
      discriminator-value="TransportCommandRequestACS"
    >

    <id
        name="Id"
        column="id"
        type="System.String"
        length="64"
        unsaved-value="null"
        >
      <generator class="assigned">
        <!--  
                  To add non XDoclet generator parameters, create a file named 
                  hibernate-generator-params-Carrier.xml 
                  containing the additional parameters and place it in your merge dir. 
              -->
      </generator>
    </id>

    <property
        name="MessageName"
        type="System.String"
        update="true"
        insert="true"
        column="messageName"
        length="255"
        />

    <property
        name="JobId"
        type="System.String"
        update="true"
        insert="true"
        column="jobId"
        length="64"
        />

    <property
        name="VehicleId"
        type="System.String"
        update="true"
        insert="true"
        column="vehicleId"
        length="64"
        />

    <property
        name="Dest"
        type="System.String"
        update="true"
        insert="true"
        column="dest"
        length="64"
        />

    <property
        name="Description"
        type="System.String"
        update="true"
        insert="true"
        column="description"
        length="64"
        />

    <property
        name="CreateTime"
        type="System.DateTime"
        update="true"
        insert="true"
        column="createTime"
        />
  </class>

</hibernate-mapping>
