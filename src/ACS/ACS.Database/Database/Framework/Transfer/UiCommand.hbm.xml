<?xml version="1.0" encoding="utf-8" ?>

<!--//200622 Change NIO Logic About ES.exe does not restart-->

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="ACS.Framework"
                   namespace="ACS.Framework.Transfer.Model">

  <class name="UiCommand" table="NA_U_COMMAND" dynamic-update="true" dynamic-insert="true">
    <id name="ID" column="ID" type="System.String" length="64" unsaved-value="null">
      <generator class="assigned"/>
    </id>
    <property name="MESSAGENAME" type="System.String" column="MESSAGENAME" update="true" insert="true" length="64"/>
    <property name="APPLICATIONNAME" type="System.String" column="APPLICATIONNAME" update="true" insert="true" length="64" />
    <property name="APPLICATIONTYPE" type="System.String" column="APPLICATIONTYPE" update="true" insert="true" length="64" />
    <property name="USERID" type="System.String" column="USERID" update="true" insert="true" length="64" />
    <property name="CAUSE" type="System.String" column="CAUSE" update="true" insert="true" length="64" />
    <property name="DESCRIPTION" type="System.String" column="DESCRIPTION" update="true" insert="true" length="256" />
    <property name="TIME" type="System.DateTime" column="TIME" update="true" insert="true"/>
  </class>
</hibernate-mapping>


