<?xml version="1.0" encoding="utf-8"?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

	<!--Trigger ref 설정 및 주기 설정-->
	<object id="awakeCallVehicleStopWaitJobTrigger" type="Spring.Scheduling.Quartz.CronTriggerObject, Spring.Scheduling.Quartz">
		<property name="jobDetail" ref="awakeCallVehicleStopWaitJob" />
		<!-- run every 16 second of minute -->
		<property name="cronExpressionString" value="16 * * * * ?" />
	</object>

	<object name="awakeCallVehicleStopWaitJob" type="Spring.Scheduling.Quartz.JobDetailObject, Spring.Scheduling.Quartz">
		<property name="JobType" value="ACS.Scheduling.AwakeCallVehicleStopWaitJob, ACS.Scheduling" />
		<!-- We can inject values throgh JobDataMap -->
		<property name="JobDataAsMap">
			<dictionary>
				<entry key="MessageAgent" value-ref="TsAgentSender" />
				<entry key="MessageManager" value-ref="MessageManager" />
				<entry key="ResourceManager"  value-ref="ResourceManager" />
				<!--<entry key="Elapsed" value="10000"/>-->
				<!-- milli -->
				<!--
        <entry key="Interval" value="200"/>
        -->
				<!-- milli -->
				<!--
        <entry key="MaxAwakeCount"  value="10"/>-->
			</dictionary>
		</property>
	</object>

</objects>
