<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">


  <object id="awakeHeartBeatFailHistoryTrigger" type="Spring.Scheduling.Quartz.CronTriggerObject, Spring.Scheduling.Quartz">
    <property name="jobDetail" ref="awakeHeartBeatFailHistoryJobDetail" />
    <!-- 10:20 every day -->
    <property name="cronExpressionString" value="0 20 10 * * ?" />
  </object>


  <object name="awakeHeartBeatFailHistoryJobDetail" type="Spring.Scheduling.Quartz.JobDetailObject, Spring.Scheduling.Quartz">
    <property name="JobType" value="ACS.Scheduling.Awake.AwakeTruncateHistoryJob, ACS.Scheduling" />
    <!-- We can inject values throgh JobDataMap -->
    <property name="JobDataAsMap">
      <dictionary>
        <entry key="PersistentDao" value-ref="PersistentDao" />
        <entry key="HistoryManager" value-ref ="HistoryManager" />
        <entry key="TableName">
          <value>NA_H_HEARTBEATFAILHISTORY</value>
        </entry>
      </dictionary>
    </property>
  </object>

</objects>

