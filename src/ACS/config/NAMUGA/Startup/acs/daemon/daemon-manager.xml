<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <object id="ApplicationEventListener" type="ACS.Application.ApplicationEventListener, ACS.Application"
		lazy-init="default" autowire="default" dependency-check="default">
    <property name="AfterContextInitialized">
      <object
				type="ACS.Application.AfterContextInitialized, ACS.Application"
				lazy-init="default" autowire="default" dependency-check="default" />
    </property>
  </object>
  
  <object id="AbstractManager" abstract="true" type="ACS.Framework.Base.AbstractManager, ACS.Framework">
    <property name="PersistentDao" ref="PersistentDao" />
    <property name="LogManager" ref="LogManager"/>
  </object>

  <object id="ApplicationManager" parent="AbstractManager" type="ACS.Application.ApplicationManagerImplement, ACS.Application"
		lazy-init="default" autowire="default" dependency-check="default">
  </object>

  <object id="DaemonServerManager" parent="AbstractManager" type="ACS.Scheduling.Implement.DaemonServerManagerImplement, ACS.Scheduling" lazy-init="default" autowire="default" dependency-check="default">
    <property name="SchedulingManager" ref="SchedulingManager" />
  </object>
  
  <object id="SchedulingManager" parent="AbstractManager" type="ACS.Framework.Scheduling.SchedulingManagerImplement, ACS.Framework" lazy-init="default" autowire="default" dependency-check="default">
    <property name="Scheduler" ref="SchedulerFactoryBean" />
  </object>
  
  <object id="MessageNode" type="ACS.Framework.Message.MessageNode, ACS.Framework"/>
  
  <object id="MessageManager" parent="AbstractManager" type="ACS.Manager.Message.MessageManagerExImplement, ACS.Manager"
      init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="MessageTemplatePath">
      <value>config/@{site}/startup/message/nanotrans-message-template.xml</value>
    </property>
    <property name="ApplicationManager" ref ="ApplicationManager" />
    <!--<property name="SecsInterfaceManager" ref="SecsInterfaceManager" />-->
  </object>

  <!--//200622 Change NIO Logic About ES.exe does not restart-->
  <!--<object id="ResourceManager" parent="AbstractManager" type="ACS.Manager.Resource.ResourceManagerExImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">-->
  <object id="ResourceManager" parent="AbstractManager" type="ACS.Extension.Manager.ResourceManagerExsImplement, ACS.Extension.Manager" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ApplicationManager" ref ="ApplicationManager" />
    <property name="MaterialManager"  ref ="MaterialManager" />
  </object>

  <object id="MaterialManager" parent="AbstractManager" type="ACS.Manager.Material.MaterialManagerExImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref ="ResourceManager" />
  </object>

  <object id="TransferManager" parent="AbstractManager" type="ACS.Manager.Transfer.TransferManagerExImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="ApplicationManager" ref="ApplicationManager" />
    <property name="MaterialManager" ref ="MaterialManager" />
    <property name="HistoryManager" ref ="HistoryManager" />
  </object>

  <object id="HistoryManager" parent="AbstractManager" type="ACS.Manager.History.HistoryManagerExImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref ="ResourceManager" />
    <property name="MaterialManager"  ref="MaterialManager" />
  </object>

  <!--//200630 REFRESHCACHE-->
  <object id="CacheManager" parent="AbstractManager" type="ACS.Extension.Manager.CacheManagerExImplement, ACS.Extension.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
  </object>

  <object name="appConfigPropertyHolder" type="Spring.Objects.Factory.Config.PropertyPlaceholderConfigurer, Spring.Core">
    <property name="configSections">
      <value>Destination</value>
    </property>
  </object>

  <object id="SchedulerFactoryBean"
		type="Spring.Scheduling.Quartz.SchedulerFactoryObject, Spring.Scheduling.Quartz">
  </object>

  <object id="LogManager" type="ACS.Framework.Logging.Implement.LogManagerImpl, ACS.Framework">
    <property name="PersistentDao" ref ="PersistentDao" />
    <property name="MessageNode" ref ="MessageNode" />
    <property name="UseAdoDotNetAppender">
      <value>false</value>
    </property>
    <property name="UsePhysicalPartitioningTable">
      <value>false</value>
    </property>
    <property name="UseShortClassNameAtOperationName">
      <value>true</value>
    </property>
    <property name="LogLevel">
      <value>DEBUG</value>
    </property>
    <!-- DEBUG|INFO|FINE|WELL|WARN|ERROR|FATAL -->
    <property name="SkipLoggingMessages">
      <list>
      </list>
    </property>
  </object>
</objects>