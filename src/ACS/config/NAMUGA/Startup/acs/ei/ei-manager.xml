<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <object id="ApplicationEventListener" type="ACS.Application.ApplicationEventListener, ACS.Application"
        lazy-init="default" autowire="default" dependency-check="default">
    <property name="AfterContextInitialized">
      <object
                type="ACS.Application.AfterContextInitializedEx, ACS.Application"
                lazy-init="default" autowire="default" dependency-check="default" />
    </property>
  </object>

  <object id="AbstractManager" abstract="true" type="ACS.Framework.Base.AbstractManager, ACS.Framework">
    <property name="PersistentDao" ref="PersistentDao"/>
    <property name="LogManager" ref="LogManager"/>
  </object>

  <object id="ApplicationManager" parent="AbstractManager" type="ACS.Application.Implement.ApplicationManagerACSImplement, ACS.Application" init-method="Init" lazy-init="default" autowire="default" dependency-check="default"/>

  <object id="NioInterfaceManager" parent="AbstractManager" type="ACS.Communication.Socket.NioInterfaceManager, ACS.Communication" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="DuplicateChecker" ref="DuplicateChecker"/>
  </object>
  
  <object id="AlarmManager" parent="AbstractManager" type="ACS.Manager.Alarm.AlarmManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="HistoryManager" ref="HistoryManager"/>
  </object>

  <object id="HistoryManager" parent="AbstractManager" type="ACS.Extension.Manager.HistoryManagerExsImplement, ACS.Extension.Manager" lazy-init="default" autowire="default" dependency-check="default">
  </object>

  <object id="CacheManager" parent="AbstractManager" type="ACS.Extension.Manager.CacheManagerExImplement, ACS.Extension.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
  </object>

  <object id="PathManager" parent="AbstractManager" type="ACS.Extension.Manager.PathManagerExsImplement, ACS.Extension.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="TransferManager" ref="TransferManager"/>
    <property name="AlarmManager" ref="AlarmManager"/>
    <property name="MaxHoppingCount">
      <value>300</value>
    </property>
    <property name="MaxTotalCost">
      <value>10000</value>
    </property>
    <property name="UseDynamicLoad">
      <value>false</value>
    </property>
    <property name="UseHeuristicDelay">
      <value>false</value>
    </property>
    <property name="Comparator">
      <object
        type="ACS.Extension.Framework.Path.Comparator.WeightComparator, ACS.Extension.Framework"
         lazy-init="default" autowire="default" dependency-check="default"/>
    </property>
    <property name="NodeCheckTimeComparator" >
      <object
        type="ACS.Extension.Framework.Path.Comparator.NodeCheckTimeComparator, ACS.Extension.Framework"
        lazy-init="default" autowire="default" dependency-check="default"/>
    </property>
  </object>

  <object id="TransferManager" parent="AbstractManager" type="ACS.Manager.Transfer.TransferManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
    <property name="ApplicationManager" ref="ApplicationManager"/>
    <property name="MaterialManager" ref="MaterialManager"/>
    <property name="HistoryManager" ref="HistoryManager"/>
  </object>
   
  <object id="DuplicateChecker" type="ACS.Communication.Socket.Checker.DuplicatedCheckerImpl, ACS.Communication" lazy-init="default" autowire="default" dependency-check="default"/>

  <object id="MessageManager" parent="AbstractManager" type="ACS.Extension.Manager.MessageManagerExsImplement, ACS.Extension.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="MessageTemplatePath">
      <value>Config/@{site}/StartUp/Message/Nanotrans-message-template.xml</value>
    </property>
    <property name="MessageNode" ref="MessageNode"/>
    <property name="ApplicationManager" ref="ApplicationManager"/>
    <property name="TsAgent" ref="TransAgentSender"/>
  </object>

  <object id="ResourceManager" parent="AbstractManager" type="ACS.Extension.Manager.ResourceManagerExsImplement, ACS.Extension.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ApplicationManager" ref="ApplicationManager"/>
    <property name="MaterialManager" ref="MaterialManager"/>
  </object>

  <object id="MaterialManager" parent="AbstractManager" type="ACS.Manager.Material.MaterialManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
  </object>

  <object id="SchedulerFactoryObject" type="Spring.Scheduling.Quartz.SchedulerFactoryObject, Spring.Scheduling.Quartz">
    <!--<property name="StartupDelay">
      <value>5</value>
    </property>-->
    <property name ="triggers">
      <list>
        <ref object ="HeartBeatJobTrigger"/>
      </list>
    </property>
  </object>

  <object id="HeartBeatJobTrigger" type="Spring.Scheduling.Quartz.CronTriggerObject, Spring.Scheduling.Quartz">
    <property name="jobDetail" ref="HeartBeatJobDetail" />
    <property name="cronExpressionString" value="*/20 * * * * ?" />
  </object>

  <object name="HeartBeatJobDetail" type="Spring.Scheduling.Quartz.JobDetailObject, Spring.Scheduling.Quartz">
    <property name="JobType" value="ACS.EI.Scheduling.VehicleHeartBeatJob, ACS.EI" />
    <property name="JobDataAsMap">
      <dictionary>
        <entry key="ResourceManager"  value-ref="ResourceManager" />
        <entry key="NioInterfaceManager" value-ref="NioInterfaceManager" />
        <entry key="ApplicationManager" value-ref="ApplicationManager" />
      </dictionary>
    </property>
  </object>

  <object id="MessageNode" type="ACS.Framework.Message.MessageNode, ACS.Framework" lazy-init="default" autowire="default" dependency-check="default"/>

  <object name="appConfigPropertyHolder" type="Spring.Objects.Factory.Config.PropertyPlaceholderConfigurer, Spring.Core">
    <property name="configSections">
      <value>Destination</value>
    </property>
  </object>

  <object id="RequestManager" parent="AbstractManager" type="ACS.Manager.Transfer.RequestManagerExImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
  </object>


  <object id="LogManager" type="ACS.Framework.Logging.Implement.LogManagerImpl, ACS.Framework">
    <property name="PersistentDao" ref ="PersistentDao" />
    <property name="MessageNode" ref ="MessageNode" />
    <property name="UseAdoDotNetAppender">
      <value>false</value>
    </property>
    <property name="UsePhysicalPartitioningTable">
      <value>false</value>
    </property>
    <property name="UseShortClassNameAtOperationName">
      <value>true</value>
    </property>
    <property name="LogLevel">
      <value>DEBUG</value>
    </property>
    <!-- DEBUG|INFO|FINE|WELL|WARN|ERROR|FATAL -->
    <property name="SkipLoggingMessages">
      <list>
      </list>
    </property>
  </object>

