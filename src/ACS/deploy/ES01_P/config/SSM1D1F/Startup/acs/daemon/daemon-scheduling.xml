<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <!--Trigger 정의-->
  
  <object type="Spring.Scheduling.Quartz.SchedulerFactoryObject, Spring.Scheduling.Quartz">
    <property name="triggers">
      <list>
        <!--<ref object="cronTrigger" />-->
        <!--<ref object="awakeChargedTransportJobTrigger" />-->
        <ref object="awakeQueuedTransportJobTrigger" />
        <ref object="awakeDeleteVehicleCrossWaitTrigger" />
        <ref object="awakeDeleteUiInformTrigger" />
        <ref object="awakeCheckCrossNodeTrigger" />
        <ref object="awakeCheckVehiclesTrigger" />
        <ref object="awakeDeleteLogTrigger" />
        <!--History-->
        <ref object="awakeLogHistoryTrigger" />
        <!--<ref object="awakeLargeLogHistoryTrigger" />-->
        <ref object="awakeTransportCommandHistoryTrigger" />
        <ref object="awakeAlarmReportHistoryTrigger" />
        <ref object="awakeHeartBeatFailHistoryTrigger" />
        <ref object="awakeVehicleHistoryTrigger" />
        <ref object="awakeTransactionHistoryTrigger" />
        <ref object="awakeUserHistoryTrigger" />
        <ref object="awakeVehicleBatteryHistoryTrigger" />
      </list>
    </property>
  </object>

</objects>