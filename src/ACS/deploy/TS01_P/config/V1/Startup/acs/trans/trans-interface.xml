  <!-- SENDER -->
  <object id="HostAgentSender" parent="AbstractHostRabbitMQ" type="ACS.Communication.Msb.RabbitMQ.GenericRabbitMQSender, ACS.Communication"  init-method="Init">
    <property name="DefaultDestination" ref="HostSenderDestination"/>
    <property name="Name">
      <value>HOSTSENDER</value>
    </property>
    <property name="CastOption">
      <value>UNICAST</value>
    </property>
    <property name="DefaultTTL">
