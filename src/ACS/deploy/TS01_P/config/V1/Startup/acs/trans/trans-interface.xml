    </property>

    <property name="SessionId">
      <value>TS.ES.LISTENER</value>
    </property>
    -->
  </object>

  <object name="UiListener" parent="AbstractRabbitMQ" type="ACS.Communication.Msb.RabbitMQ.GenericWorkflowRabbitMQListener, ACS.Communication" init-method="Init">
