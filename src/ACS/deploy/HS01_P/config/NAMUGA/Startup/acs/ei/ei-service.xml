<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <object id="VehicleInterfaceService" type="ACS.Service.VehicleInterfaceServiceEx, ACS.Service">
    <property name="NioInterfaceManager" ref ="NioInterfaceManager"/>
    <property name="ResourceManager" ref ="ResourceManager"/>
    <property name="ApplicationManager" ref ="ApplicationManager"/>
  </object>

  <object id="interfaceService" type="ACS.Service.InterfaceServiceEx, ACS.Service">
    <property name="MessageManager" ref ="MessageManager"/>
    <property name="ResourceManager" ref ="ResourceManager"/>
  </object>

  <object id="ResourceService" parent="AbstractService" type="ACS.Service.ResourceServiceEx, ACS.Service"  init-method="Init">
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="AlarmManager" ref="AlarmManager" />
    <property name="PathManager" ref="PathManager" />
    <property name="TransferManager" ref="TransferManager" />
    <property name="MessageManager" ref="MessageManager" />
    <property name="NioInterfaceManager" ref="NioInterfaceManager"/>
    <property name="CrossWaitTimeout">
      <value>120</value>
    </property>
  </object>

  <object id="TransferService" parent="AbstractService" type="ACS.Service.TransferServiceEx, ACS.Service"  init-method="Init">
    <property name="TransferManager" ref="TransferManager" />
    <property name="PathManager" ref="PathManager" />
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="RequestManagerExImplement" ref="RequestManager"/>
  </object>

  <object id="AbstractService" abstract="true" type="ACS.Framework.Base.AbstractServiceEx, ACS.Framework.Base">
    <property name="ApplicationManager" ref="ApplicationManager" />
    <property name="MessageManager" ref="MessageManager" />
    <property name="HistoryManager" ref="HistoryManager" />
    <property name="LogManager" ref="LogManager"/>
  </object>

  <object id="HistoryService" parent="AbstractService" type="ACS.Service.HistoryServiceEx, ACS.Service"  init-method="Init">
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="LogManager" ref="LogManager"/>
  </object>


</objects>