<?xml version="1.0" encoding="UTF-8"?>
<mapping>	
	<send>
		<event name="TRSMOVEREPORT" method="reportTransportJobCreated"
		           class="ACS.Framework.Message.Model.Host.AGVMoveReport"
		            host-message-name="TRSMOVEREPORT"
		            use="false" />
		<event name="TRSSTATEREPORT" method="reportTransportJobCreated"
		           class="ACS.Framework.Message.Model.Host.AGVStateReport"
		            host-message-name="TRSSTATEREPORT"
		            use="true" />		            
		<event name="TRSALARMREPORT" method="reportTransportJobCreated"
		           class="ACS.Framework.Message.Model.Host.AGVAlarmReport"
		            host-message-name="TRSALARMREPORT"
		            use="false" />
		<event name="TRSJOBREPORT" method="reportTransportJobCreated"
		           class="ACS.Framework.Message.Model.Host.AGVJobReport"
		            host-message-name="TRSJOBREPORT"
		            use="true" />
