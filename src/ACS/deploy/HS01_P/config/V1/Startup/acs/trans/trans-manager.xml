<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <object id="ApplicationEventListener" type="ACS.Application.ApplicationEventListener, ACS.Application"
        lazy-init="default" autowire="default" dependency-check="default">
    <property name="AfterContextInitialized">
      <object
                type="ACS.Application.AfterContextInitializedEx, ACS.Application"
                lazy-init="default" autowire="default" dependency-check="default" />
    </property>
  </object>

  <object id="AbstractManager" abstract="true" type="ACS.Framework.Base.AbstractManager, ACS.Framework">
    <property name="PersistentDao" ref="PersistentDao"/>
    <property name="LogManager" ref="LogManager"/>
  </object>

  <object id="ApplicationManager" parent="AbstractManager" type="ACS.Application.ApplicationManagerImplement, ACS.Application" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
  </object>
  
  <object id="ResourceManager" parent="AbstractManager" type="ACS.Manager.ResourceManagerExsImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="TransferManager" ref="TransferManager"/>
    <property name="AlarmManager" ref="AlarmManager"/>
    <property name="ApplicationManager" ref="ApplicationManager"/>
    <property name="MaterialManager" ref="MaterialManager"/>
    <property name="HistoryManager" ref="HistoryManager"/>
    <property name="CacheManager" ref="CacheManager"/>
  </object>

  <object id="TransferManager" parent="AbstractManager" type="ACS.Manager.Transfer.TransferManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
    <property name="ApplicationManager" ref="ApplicationManager"/>
    <property name="MaterialManager" ref="MaterialManager"/>
    <property name="HistoryManager" ref="HistoryManager"/>
  </object>

  <object id="AlarmManager" parent="AbstractManager" type="ACS.Manager.Alarm.AlarmManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="HistoryManager" ref="HistoryManager"/>
  </object>

  <object id="MaterialManager" parent="AbstractManager" type="ACS.Manager.Material.MaterialManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
  </object>

  <object id="PathManager" parent="AbstractManager" type="ACS.Manager.PathManagerExsImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="TransferManager" ref="TransferManager"/>
    <property name="AlarmManager" ref="AlarmManager"/>
    <property name="ResourceManager" ref="ResourceManager"/>
    <property name="HistoryManager" ref="HistoryManager"/>
    <property name="CacheManager" ref="CacheManager"/>
    <property name="MaxHoppingCount">
      <value>300</value>
    </property>
    <property name="MaxTotalCost">
      <value>10000</value>
    </property>
    <property name="UseDynamicLoad">
      <value>false</value>
    </property>
    <property name="UseHeuristicDelay">
      <value>false</value>
    </property>
    <property name="Comparator">
      <object 
        type="ACS.Framework.Path.Comparator.WeightComparator, ACS.Framework"
         lazy-init="default" autowire="default" dependency-check="default"/>
    </property>
    <property name="NodeCheckTimeComparator" >
      <object 
        type="ACS.Framework.Path.Comparator.NodeCheckTimeComparator, ACS.Framework" 
        lazy-init="default" autowire="default" dependency-check="default"/>
    </property>
  </object>

  <object id="CacheManager" parent="AbstractManager" type="ACS.Manager.CacheManagerExImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
  </object>

  <object id="MessageManager" parent="AbstractManager" type="ACS.Manager.MessageManagerExsImplement, ACS.Manager" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="MessageTemplatePath">
      <value>Config/@{site}/StartUp/Message/Nanotrans-message-template.xml</value>
    </property>
    <property name="MessageNode" ref="MessageNode"/>
    <property name="ApplicationManager" ref="ApplicationManager"/>
    <property name="ResourceManager" ref="ResourceManager"/>
    <property name="TransferManager" ref="TransferManager"/>
    <property name="NioInterfaceManager" ref="NioInterfaceManager"/>
    <property name="EsAgent" ref="EsAgentSender"/>
    <!--property name="UiAgent" ref="UiAgentSender"/-->
  </object>

  <object id="NioInterfaceManager" parent="AbstractManager" type="ACS.Communication.Socket.NioInterfaceManager, ACS.Communication" init-method="Init" lazy-init="default" autowire="default" dependency-check="default">
    <property name="DuplicateChecker" ref="DuplicateChecker"/>
  </object>

  <object id="DuplicateChecker" type="ACS.Communication.Socket.Checker.DuplicatedCheckerImpl, ACS.Communication" lazy-init="default" autowire="default" dependency-check="default"/>

  <object id="MessageNode" type="ACS.Framework.Message.MessageNode, ACS.Framework"/>
 
  <object id="HistoryManager" parent="AbstractManager" type="ACS.Manager.HistoryManagerExsImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
    <property name="ResourceManager" ref="ResourceManager"/>
  </object>

  <object id="HostMessageManager" parent="AbstractManager" type="ACS.Manager.Host.HostMessageManagerImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
    <property name="HostAgent" ref ="HostAgentSender" />
    <property name="DefaultSynchronousHostAgent" ref="HostAgentSender" />
    <property name="MsbConverter" ref="MsbConverter"/>
  </object>

  <object id="RequestManager" parent="AbstractManager" type="ACS.Manager.Transfer.RequestManagerExImplement, ACS.Manager" lazy-init="default" autowire="default" dependency-check="default">
  </object>

  <object id="MsbConverter" type="ACS.Communication.Msb.Convert.Implement.MsbXmlConverterExImplement, ACS.Communication" init-method="Init">
    <property name="MessagesMappingFilePath">
      <value>${server.trans.host.message.mapping}</value>
    </property>
    <property name="ReceiveMessageTemplateFilePath">
      <value>${server.trans.host.message.receive}</value>
    </property>
    <property name="SendMessageTemplateFilePath">
      <value>${server.trans.host.message.send}</value>
    </property>
    <property name="XpathOfMessageName">
      <value>${server.trans.xpathofmessagename.host}</value>
    </property>
    <!-->property name="MessageSourceAccessor" ref="MessageSourceAccessor" /-->
    <property name="MsbValueConverter" ref="MsbValueConverter" />
  </object>

  <object id="MsbValueConverter" type="ACS.Communication.Msb.Convert.Implement.MsbValueConverterImpl, ACS.Communication" init-method="Init">
    <property name="TransferManager" ref="TransferManager" />
  </object>
   
  <object id="LogManager" type="ACS.Framework.Logging.Implement.LogManagerImpl, ACS.Framework">
    <property name="PersistentDao" ref ="PersistentDao" />
    <property name="MessageNode" ref ="MessageNode" />
    <property name="UseAdoDotNetAppender">
      <value>true</value>
    </property>
    <property name="UsePhysicalPartitioningTable">
      <value>false</value>
    </property>
    <property name="UseShortClassNameAtOperationName">
      <value>true</value>
    </property>
    <property name="LogLevel">
      <value>DEBUG</value>
    </property>
    <!-- DEBUG|INFO|FINE|WELL|WARN|ERROR|FATAL -->
    <property name="SkipLoggingMessages">
      <list>
      </list>
    </property>
  </object>

  <!-->object id="MessageSourceAccessor" type="Spring.Context.Support.MessageSourceAccessor, Spring.Core">
      <constructor-arg>
        <ref local="MessageSource" />
      </constructor-arg>
  </object-->

  <!-->object id="MessageSource" type="Spring.Context.Support.ResourceSetMessageSource, Spring.Core">
  </object-->
	
</objects>