<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <object id="AstractService" abstract="true" type="ACS.Framework.Base.AbstractService, ACS.Framework.Base">
    <property name="ApplicationManager" ref="ApplicationManager" />
    <property name="MessageManager" ref="MessageManager" />
    <property name="HistoryManager" ref="HistoryManager" />
    <property name="LogManager" ref="LogManager"/>
  </object>

  <object id="InterfaceService" parent="AstractService" type="ACS.Service.InterfaceServiceEx, ACS.Service"  init-method="Init">
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="TransferManager" ref="TransferManager" />
    <property name="HostMessageManager" ref="HostMessageManager" />
    <property name="AlarmManager" ref="AlarmManager" />
    <property name="PathManager" ref="PathManager" />
    <property name="LogManager" ref="LogManager"/>
  </object>

  <object id="TransferService" parent="AstractService" type="ACS.Service.TransferServiceEx, ACS.Service"  init-method="Init">
    <property name="TransferManager" ref="TransferManager" />
    <property name="PathManager" ref="PathManager" />
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="RequestManagerExImplement" ref="RequestManager"/>
  </object>

  <object id="MaterialService" parent="AstractService" type="ACS.Service.MaterialServiceEx, ACS.Service"  init-method="Init">
    <property name="MaterialManager" ref="MaterialManager" />
    <property name="TransferManager" ref="TransferManager" />
  </object>

  <object id="ResourceService" parent="AstractService" type="ACS.Service.ResourceServiceEx, ACS.Service"  init-method="Init">
    <property name="ResourceManager" ref="ResourceManager" />
    <property name="AlarmManager" ref="AlarmManager" />
    <property name="PathManager" ref="PathManager" />
    <property name="TransferManager" ref="TransferManager" />
    <property name="MessageManager" ref="MessageManager" />
    <property name="NioInterfaceManager" ref="NioInterfaceManager"/>
    <property name="CrossWaitTimeout">
      <value>120</value>
    </property>
  </object>

  <object id="AlarmService" parent="AstractService" type="ACS.Service.AlarmServiceEx, ACS.Service"  init-method="Init">
    <property name="AlarmManager" ref="AlarmManager" />
    <property name="PathManager" ref="PathManager" />
  </object>
  <object id="DataHandlingService" parent="AstractService" type="ACS.Service.DataHandlingServiceEx, ACS.Service"  init-method="Init"/>
  <object id="HistoryService" parent="AstractService" type="ACS.Service.HistoryServiceEx, ACS.Service"  init-method="Init"/>
  <object id="VehicleInterfaceService" parent="AstractService" type="ACS.Service.VehicleInterfaceServiceEx, ACS.Service"  init-method="Init"/>
</objects>