<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <object id="awakeDeleteVehicleCrossWaitTrigger" type="Spring.Scheduling.Quartz.CronTriggerObject, Spring.Scheduling.Quartz">
    <property name="jobDetail" ref="awakeDeleteVehicleCrossWaitJob" />
    <!-- run every 20 second of minute -->
    <property name="cronExpressionString" value="0/20 * * * * ?" />
  </object>


  <object name="awakeDeleteVehicleCrossWaitJob" type="Spring.Scheduling.Quartz.JobDetailObject, Spring.Scheduling.Quartz">
    <property name="JobType" value="ACS.Scheduling.AwakeDeleteVehicleCrossWaitJob, ACS.Scheduling" />
    <!-- We can inject values throgh JobDataMap -->
    <property name="JobDataAsMap">
      <dictionary>        
        <entry key="ResourceManager" value-ref ="ResourceManager" />
        <entry key="SavePeriod" value="60"/>
        <!-- sec -->
      </dictionary>
    </property>
  </object>

</objects>

