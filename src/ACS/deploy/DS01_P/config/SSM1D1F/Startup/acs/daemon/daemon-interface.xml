<?xml version="1.0" encoding="utf-8" ?>
<objects xmlns="http://www.springframework.net" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.net http://www.springframework.net/xsd/spring-objects.xsd">

  <!-- set to application -->
  <object id="ApplicationDefaultDestinationName" type="ACS.Framework.Application.Model.ApplicationDefaultDestinationName, ACS.Framework" init-method="Init">
    <property name="DestinationName">
      <value>${server.daemon.ts.sender.destination}</value>
    </property>
  </object>

  <!-- destination -->
  <object id="UiSenderDestination" type="ACS.Communication.Msb.Highway101.ChannelDestination, ACS.Communication">
    <property name="Name">
      <value>${server.daemon.ui.sender.destination}</value>
    </property>
  </object>
  <object id="AcsSenderDestination" type="ACS.Communication.Msb.Highway101.ChannelDestination, ACS.Communication">
    <property name="Name">
      <value>${server.daemon.ts.sender.destination}</value>
    </property>
  </object>
  <!-- If acs need to send message to es, you have to activated this. -->
  <!-- ><bean id="esSenderDestination" class="kr.co.samsung.sds.nanotrans.communication.msb.highway101.ChannelDestination">
		<property name="name"><value>${server.daemon.ei.sender.destination}</value></property>
	</bean> -->

  <object id="AbstractHighway101" abstract="true" type="ACS.Communication.Msb.Highway101.AbstractHighway101, ACS.Communication" init-method="Init">
    <property name="ConnectUrl">
      <!--<value>127.0.0.1:10101</value>-->
      <value>${server.domain.connecturl}</value>
    </property>
    <property name="StationMode">
      <!--<value>INTER</value>-->
      <value>${server.domain.stationmode}</value>
    </property>
    <!--<property name="logManager"><ref bean="logManager" /></property>
    -->
  </object>

  <!-- sender -->
  <object id="TsAgentSender" parent="AbstractHighway101" type=" ACS.Communication.Msb.Highway101.Marker.TransSender, ACS.Communication " init-method="Init">
    <property name="DefaultDestination" ref="AcsSenderDestination"/>
    <property name="Name">
      <value>TsAgentSender</value>
    </property>
    <property name="SessionId">
      <value>DS.TS.SENDER</value>
    </property>
    <property name="CastOption">
      <value>UNICAST</value>
    </property>
    <property name="DeliveryMode">
      <value>PULL</value>
    </property>
    <property name="AutoRecoveryOption">
      <value>true</value>
    </property>
    <property name="DefaultTTL">
      <value>60000</value>
    </property>
  </object>
  
  <object id="UiAgentSender" parent="AbstractHighway101" type=" ACS.Communication.Msb.Highway101.Marker.UiSender, ACS.Communication" init-method="Init">
    <property name="DefaultDestination" ref="UiSenderDestination"/>
    <property name="Name">
      <value>UiAgentSender</value>
    </property>
    <property name="SessionId">
      <value>DS.GUI.SENDER</value>
    </property>
    <property name="CastOption">
      <value>UNICAST</value>
    </property>
    <property name="DeliveryMode">
      <value>PULL</value>
    </property>
    <property name="AutoRecoveryOption">
      <value>true</value>
    </property>
    <property name="DefaultTTL">
      <value>60000</value>
    </property>
  </object>

</objects>